<gambezi>
    <paths>
        <staging>tmp</staging>
    </paths>
    <apps>
	<app name="logger">
		<url>https://github.com/ClearCreekSci/ccs_data_logger/archive/refs/heads/main.zip</url>
		<!-- <url>https://github.com/ClearCreekSci/ccs_data_logger/archive/refs/tags/v1-test-not-for-release.zip</url> -->
		<meta-url>https://github.com/ClearCreekSci/ccs_data_logger/releases/tag/v1-test-not-for-release</meta-url>

	    <desc>Collect and store data from sensors</desc>
	    <subs>
                <url name="ccs_dl_config">https://github.com/ClearCreekSci/ccs_dlconfig/archive/refs/heads/main.zip</url>
		<url name="ccs_base">https://github.com/ClearCreekSci/ccs_base/archive/refs/heads/main.zip</url>
	    </subs>
        </app>
        <app name="server">
            <url>https://github.com/ClearCreekSci/ccs_dl_browser/archive/refs/heads/main.zip</url>
            <desc>Display collected data in a web browser</desc> 
	    <subs>
                <url name="ccs_dl_config">https://github.com/ClearCreekSci/ccs_dlconfig/archive/refs/heads/main.zip</url>
		<url name="ccs_base" dst="databrowser">https://github.com/ClearCreekSci/ccs_base/archive/refs/heads/main.zip</url>
	    </subs>
        </app>
    </apps>
    <modules>
        <module name="bme280">
            <url>https://github.com/ClearCreekSci/bme280_ccs_sensor/archive/refs/heads/main.zip</url>
	    <desc>Measure air temperature, barometric pressure and humidity</desc>
	    <!-- The following values are overloaded. The "loader" tag indicates which app will load -->
	    <!-- the module, as well as being the namespace for UI types (such as logger:sensor) -->
	    <!-- The "prefix" tag indicates the directory where the module will be stored in the final -->
	    <!-- installation, with a 'mods' suffix (i.e. sensormods), as well as being the name -->
	    <!-- of certain UI types (such as logger:sensor). Kind of confusing, but I think it will work -->
	    <loader>logger</loader>
	    <prefix>sensor</prefix>
        </module>
    </modules>
</gambezi>


